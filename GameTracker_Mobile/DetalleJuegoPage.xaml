<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameTracker_Mobile.DetalleJuegoPage"
             Title="Sesión de Juego"
             BackgroundColor="#121212"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="15">
            <Label x:Name="lblNombre" 
                   TextColor="Lime" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Button Text="VER HISTORIAL DE NOTAS" 
                    Clicked="OnVerNotasClicked" 
                    BackgroundColor="#333333" 
                    TextColor="White" 
                    Margin="0,10" />

            <Label Text="¿QUÉ LOGRASTE HOY?" TextColor="Gray" />

            <Editor x:Name="txtNotas" 
                    HeightRequest="100" 
                    TextColor="White" 
                    BackgroundColor="#1E1E1E" 
                    Placeholder="Escribe aquí tus logros..." />

            <Label Text="HISTORIAL ACTUAL:" TextColor="Gray" FontSize="12" Margin="0,10,0,0"/>
            <Label x:Name="lblHistorial" 
                   TextColor="#CCCCCC" 
                   FontSize="14" />

            <BoxView HeightRequest="1" Color="#333333" Margin="0,10" />

            <Label Text="TIEMPO JUGADO HOY" TextColor="Lime" FontAttributes="Bold" HorizontalOptions="Center" />

            <Grid ColumnDefinitions="*, Auto, *, Auto" HorizontalOptions="Center">
                <Picker x:Name="pickerHoras" Title="0" WidthRequest="80" TextColor="White" Grid.Column="0" />
                <Label Text="hrs" TextColor="Gray" VerticalOptions="Center" Grid.Column="1" Margin="5,0,20,0"/>

                <Picker x:Name="pickerMinutos" Title="0" WidthRequest="80" TextColor="White" Grid.Column="2" />
                <Label Text="min" TextColor="Gray" VerticalOptions="Center" Grid.Column="3" Margin="5,0,0,0"/>
            </Grid>

            <Button Text="GUARDAR Y SUMAR TIEMPO" 
                    Clicked="OnGuardarClicked" 
                    BackgroundColor="Lime" 
                    TextColor="Black" 
                    FontAttributes="Bold" 
                    HeightRequest="50" />

            <Button Text="VOLVER A BIBLIOTECA" 
                    Clicked="OnVolverClicked" 
                    BackgroundColor="Transparent" 
                    TextColor="#AAAAAA" 
                    BorderColor="#444444" 
                    BorderWidth="1" 
                    Margin="0,10,0,0"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>