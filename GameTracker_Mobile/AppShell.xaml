<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GameTracker_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:GameTracker_Mobile"
    Shell.FlyoutBehavior="Flyout"
    FlyoutBackgroundColor="#1E1E1E">

    <Shell.ItemTemplate>
        <DataTemplate>
            <Grid Padding="15">
                <Label Text="{Binding Title}" 
                       TextColor="Lime" 
                       FontSize="18" 
                       VerticalOptions="Center" 
                       FontAttributes="Bold" 
                       Margin="20,0,0,0"/>
            </Grid>
        </DataTemplate>
    </Shell.ItemTemplate>

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20" BackgroundColor="#121212">
            <Label Text="GAME TRACKER" TextColor="Lime" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" />
            <BoxView HeightRequest="2" Color="Lime" Margin="0,10,0,0" />
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Agregar Juego">
        <ShellContent Title="GAME TRACKER" ContentTemplate="{DataTemplate local:MainPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Ver Mi Biblioteca">
        <ShellContent Title="MI BIBLIOTECA" ContentTemplate="{DataTemplate local:ListaJuegosPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Borrar Juego">
        <ShellContent Title="ELIMINAR JUEGOS" ContentTemplate="{DataTemplate local:EliminarJuegoPage}" />
    </FlyoutItem>
</Shell>