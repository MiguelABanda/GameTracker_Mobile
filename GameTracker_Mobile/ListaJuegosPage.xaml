<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameTracker_Mobile.ListaJuegosPage"
             Title="MI BIBLIOTECA"
             BackgroundColor="#121212">

    <ListView x:Name="listaJuegos" ItemSelected="OnItemSelected" BackgroundColor="Transparent" SeparatorColor="Lime">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <HorizontalStackLayout Padding="15" Spacing="15">
                        <Label Text="{Binding Id}" TextColor="Lime" VerticalOptions="Center" FontAttributes="Bold" />
                        <VerticalStackLayout>
                            <Label Text="{Binding Nombre}" TextColor="White" FontSize="18" />
                            <Label Text="{Binding Plataforma}" TextColor="Gray" FontSize="12" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentPage>